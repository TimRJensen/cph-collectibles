{
	log {
		level warn
		format console
	}
}

localhost, dashboard.localhost {
	handle /api/* {
		reverse_proxy api:8080
	}

	handle /fs/* {
		reverse_proxy fs:8081
	}

	handle {
		reverse_proxy host.docker.internal:3000
	}
}

cph-collectables.com {
	handle /api/* {
		reverse_proxy cph-collectibles-api.internal:8080
	}

	handle /fs/* {
		reverse_proxy cph-collectibles-fs.internal:8081
	}

	handle {
		root * /srv/site
		encode zstd gzip
		file_server
	}
}